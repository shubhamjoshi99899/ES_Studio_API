# Application
PORT=5000
NODE_ENV=production
APP_URL=https://app.socialmetrics.io
FRONTEND_URL=*

# Auth
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
SETUP_SECRET=change-me-setup-secret

# PostgreSQL (docker-compose service name = hostname)
DB_HOST=postgres-db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_strong_password
DB_NAME=social_studio_db
DB_SSL=false

# Redis (docker-compose service name = hostname)
REDIS_HOST=redis-cache
REDIS_PORT=6379

# Google BigQuery
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-key.json
BIGQUERY_PROJECT_ID=your-project-id
BIGQUERY_DATASET=your_dataset
ANALYTICS_API_KEY=your-analytics-api-key

# Meta (Facebook/Instagram)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# SMTP (Email Reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
