      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/setup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-setup-secret", "value": "{{setupSecret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"StrongPass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/setup"
          }
        },
        {
          "name": "POST /api/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setCookieHeaders = pm.response.headers.all().filter(({ key }) => key.toLowerCase() === 'set-cookie').map(({ value }) => value);",
                  "function saveCookie(cookieName, variableName) {",
                  "  const header = setCookieHeaders.find((value) => value.startsWith(cookieName + '='));",
                  "  if (!header) return;",
                  "  const token = header.split(';')[0].slice(cookieName.length + 1);",
                  "  pm.collectionVariables.set(variableName, token);",
                  "}",
                  "saveCookie('access_token', 'accessToken');",
                  "saveCookie('refresh_token', 'refreshToken');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"StrongPass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "POST /api/auth/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setCookieHeaders = pm.response.headers.all().filter(({ key }) => key.toLowerCase() === 'set-cookie').map(({ value }) => value);",
                  "function saveCookie(cookieName, variableName) {",
                  "  const header = setCookieHeaders.find((value) => value.startsWith(cookieName + '='));",
                  "  if (!header) return;",
                  "  const token = header.split(';')[0].slice(cookieName.length + 1);",
                  "  pm.collectionVariables.set(variableName, token);",
                  "}",
                  "saveCookie('access_token', 'accessToken');",
                  "saveCookie('refresh_token', 'refreshToken');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Cookie", "value": "refresh_token={{refreshToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/refresh"
          }
        },
        {
          "name": "POST /api/auth/logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.unset('accessToken');",
                  "pm.collectionVariables.unset('refreshToken');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Cookie", "value": "access_token={{accessToken}}; refresh_token={{refreshToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/logout"
          }
        },
        {
          "name": "GET /api/auth/me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "access_token={{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "POST /api/auth/switch-workspace",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setCookieHeaders = pm.response.headers.all().filter(({ key }) => key.toLowerCase() === 'set-cookie').map(({ value }) => value);",
                  "function saveCookie(cookieName, variableName) {",
                  "  const header = setCookieHeaders.find((value) => value.startsWith(cookieName + '='));",
                  "  if (!header) return;",
                  "  const token = header.split(';')[0].slice(cookieName.length + 1);",
                  "  pm.collectionVariables.set(variableName, token);",
                  "}",
                  "saveCookie('access_token', 'accessToken');",
                  "saveCookie('refresh_token', 'refreshToken');",
                  "const json = pm.response.json();",
                  "if (json.workspaceId) pm.collectionVariables.set('workspaceId', json.workspaceId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "access_token={{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/switch-workspace"
          }
        }
      ]
